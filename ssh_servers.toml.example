# SSH 运维服务器连接示例

[sa]
host = "ops.example.com"
port = 22
user = "ubuntu"
key_path = "IFCZT_KEYS"
sudo_password = ""   # 可选，填写后 sudo 命令自动通过 -S 传入密码

[mx]
host = "ops.example.com"
port = 22
user = "ubuntu"
key_path = "IFCZT_KEYS"

[sg]
host = "ops.example.com"
port = 22
user = "ubuntu"
key_path = "IFCZT_KEYS"
