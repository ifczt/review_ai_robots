# 飞书应用凭证（在 open.feishu.cn 创建自建应用后获取）
# 长连接模式只需要 App ID 和 App Secret，无需公网 IP 或 Webhook
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI 后端选择：anthropic（推荐）/ openai / chatgpt
AI_BACKEND=anthropic

# Anthropic 原生 SDK（AI_BACKEND=anthropic 时生效）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 中转代理地址，留空则使用官方 api.anthropic.com
ANTHROPIC_BASE_URL=

# OpenAI 兼容接口（AI_BACKEND=openai 时生效）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 中转代理地址，留空则使用官方 api.openai.com
OPENAI_BASE_URL=

# ChatGPT / OpenAI GPT（AI_BACKEND=chatgpt 时生效）
CHATGPT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHATGPT_BASE_URL=
CHATGPT_MODEL=gpt-4o
CHATGPT_MAX_TOKENS=4096

# 通用模型配置
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# SSH 私钥密码（如私钥未加密可留空）
SSH_KEY_PASSPHRASE=

# 命令执行配置
CMD_TIMEOUT_SECONDS=30
CMD_WORKING_DIR=.

# Gitea 代码审查配置（不填则 /gitreview 不可用）
GITEA_BASE_URL=https://gitea.example.com
GITEA_TOKEN=your_gitea_access_token
# 合并方式：merge / rebase / squash
GITEA_AUTO_MERGE_METHOD=merge

# BW 包网测试群 chat_id（PR 合并后的测试计划通知目标）
BW_CHAT_ID=

# 每日代码审查日报接收群 chat_id
DAILY_REPORT_CHAT_ID=

# 每天 19:30 私聊发送个人代码审查日报，JSON 格式：{"gitea_author":"feishu_open_id"}
DAILY_REPORT_PRIVATE_RECIPIENTS=
DAILY_REPORT_SEND_HOUR=19
DAILY_REPORT_SEND_MINUTE=30
# 1 表示 19:30 发送昨天的日报
DAILY_REPORT_LOOKBACK_DAYS=1
